# Copie este arquivo para ".env" e preencha com os dados do SEU projeto Supabase
# (Painel do Supabase → Settings → API)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole-aqui-a-chave-anon-public

# Notificações push (chave PÚBLICA VAPID — pode ficar no front).
# Gere com o guia PUSH-SETUP.md e cole o mesmo valor aqui e na Vercel.
VITE_VAPID_PUBLIC_KEY=cole-aqui-a-chave-publica-vapid
